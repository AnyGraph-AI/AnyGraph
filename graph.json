        "sourceCode": "function toNum(v: unknown): number {\n  if (v == null) return 0;\n  if (typeof v === 'number') return v;\n  if (typeof v === 'bigint') return Number(v);\n  if (typeof (v as { toNumber?: unknown }).toNumber === 'function') {\n    return (v as { toNumber: () => number }).toNumber();\n  }\n  return Number(v);\n}",
