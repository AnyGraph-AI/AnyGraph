{
  "name": "codegraph",
  "version": "0.1.0",
  "description": "MCP server that builds code graphs to provide rich context to LLMs",
  "type": "module",
  "homepage": "https://github.com/JTheWatcher/codegraph#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JTheWatcher/codegraph.git"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "code-graph",
    "code-analysis",
    "neo4j",
    "graph-database",
    "typescript",
    "nestjs",
    "ast-parser",
    "semantic-search",
    "openai",
    "embeddings",
    "graph-rag",
    "llm",
    "claude"
  ],
  "author": "Andrew Hernandez",
  "license": "MIT",
  "main": "dist/mcp/mcp.server.js",
  "bin": {
    "codegraph": "dist/cli/cli.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "rm -rf dist && npm run build",
    "prepare": "npm run build",
    "mcp": "node dist/mcp/mcp.server.js",
    "dev": "tsc --watch",
    "graph:print": "npm run build && node dist/utils/test.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "ir:parity": "node --loader ts-node/esm src/utils/ir-parity-gate.ts",
    "ir:parity:resume": "node --loader ts-node/esm src/utils/ir-parity-gate.ts --resume --retry-failed",
    "doc:ingest": "node --loader ts-node/esm src/utils/document-adapter-ingest.ts",
    "python:parse:ir": "node --loader ts-node/esm src/utils/python-parser-ingest.ts",
    "parser:gold:harness": "node --loader ts-node/esm src/utils/parser-gold-harness.ts",
    "corpus:bible:hash-ingest": "node --loader ts-node/esm src/utils/corpus-record-hash-ingest.ts",
    "entity:identity:sync": "node --loader ts-node/esm src/utils/entity-identity-model-sync.ts",
    "audit:anchor:resolve": "node --loader ts-node/esm src/utils/audit-anchor-resolve.ts",
    "verification:ingest": "node --loader ts-node/esm src/utils/verification-foundation-ingest.ts",
    "verification:sarif:import": "node --loader ts-node/esm src/utils/verification-sarif-import.ts",
    "verification:scope:resolve": "node --loader ts-node/esm src/utils/verification-scope-resolve.ts",
    "verification:exception:enforce": "node --loader ts-node/esm src/utils/verification-exception-enforce.ts",
    "verification:advisory:gate": "node --loader ts-node/esm src/utils/verification-advisory-gate.ts",
    "verification:done-check:capture": "node --loader ts-node/esm src/utils/verification-done-check-capture.ts",
    "verification:done-check:capture:only": "node --loader ts-node/esm src/utils/verification-done-check-capture.ts --capture-only",
    "verification:pilot:ir:validate": "node --loader ts-node/esm src/utils/verification-ir-pilot-validate.ts",
    "verification:pilot:vg5:thresholds": "node --loader ts-node/esm src/utils/verification-vg5-thresholds.ts",
    "verification:proof:record": "node --loader ts-node/esm src/utils/verification-invariant-proof-records.ts",
    "verification:proof:status": "node --loader ts-node/esm src/utils/verification-done-vs-proven.ts",
    "verification:recommendation:mismatch": "node --loader ts-node/esm src/utils/verification-recommendation-mismatch.ts",
    "verification:status:dashboard": "node --loader ts-node/esm src/utils/verification-status-dashboard.ts",
    "registry:backfill": "node --loader ts-node/esm src/scripts/tools/reconcile-project-registry.ts",
    "registry:reconcile": "node --loader ts-node/esm src/scripts/tools/reconcile-project-registry.ts",
    "registry:verify": "node --loader ts-node/esm src/scripts/verify/verify-project-registry.ts",
    "registry:identity:verify": "node --loader ts-node/esm src/scripts/verify/verify-project-identity-contract.ts",
    "registry:duplicates:report": "node --loader ts-node/esm src/scripts/tools/report-project-registry-duplicates.ts",
    "code:embedding-inputs:enrich": "node --loader ts-node/esm src/scripts/enrichment/enrich-code-embedding-inputs.ts",
    "plan:embedding:match": "node --loader ts-node/esm src/scripts/tools/plan-code-embedding-matcher.ts",
    "embedding:fp:verify": "node --loader ts-node/esm src/scripts/verify/verify-embedding-fp-rate.ts",
    "integrity:snapshot:fields:verify": "node --loader ts-node/esm src/scripts/verify/verify-integrity-snapshot-fields.ts",
    "integrity:daily:job": "node --loader ts-node/esm src/scripts/verify/run-integrity-daily-job.ts",
    "governance:stale:verify": "node --loader ts-node/esm src/scripts/verify/verify-governance-stale-check.ts",
    "claims:cross:synthesize": "node --loader ts-node/esm src/scripts/enrichment/synthesize-cross-domain-claims.ts",
    "query:contract:verify": "node --loader ts-node/esm src/scripts/verify/verify-query-contract-usage.ts",
    "edges:normalize": "node --loader ts-node/esm src/scripts/enrichment/normalize-edge-project-ids.ts",
    "edges:verify": "node --loader ts-node/esm src/scripts/verify/verify-edge-tagging.ts",
    "plan:evidence:recompute": "node --loader ts-node/esm src/scripts/tools/recompute-plan-evidence-flags.ts",
    "evidence:backfill": "node --loader ts-node/esm src/utils/evidence-backfill-fast-track.ts",
    "evidence:coverage": "node --loader ts-node/esm src/utils/evidence-backfill-fast-track.ts --report-only",
    "integrity:snapshot": "node --loader ts-node/esm src/scripts/verify/graph-integrity-snapshot.ts",
    "integrity:verify": "node --loader ts-node/esm src/scripts/verify/verify-graph-integrity.ts",
    "parser:contracts:verify": "node --loader ts-node/esm src/scripts/verify/verify-parser-contracts.ts",
    "plan:deps:verify": "node --loader ts-node/esm src/scripts/verify/verify-plan-dependency-integrity.ts",
    "plan:refresh": "node --loader ts-node/esm src/utils/plan-refresh-for-gates.ts",
    "hygiene:foundation:sync": "node --loader ts-node/esm src/utils/hygiene-foundation-bootstrap.ts",
    "hygiene:foundation:verify": "node --loader ts-node/esm src/utils/verify-hygiene-foundation.ts",
    "hygiene:ownership:sync": "node --loader ts-node/esm src/utils/hygiene-ownership-sync.ts",
    "hygiene:ownership:verify": "node --loader ts-node/esm src/utils/verify-hygiene-ownership.ts",
    "hygiene:topology:sync": "node --loader ts-node/esm src/utils/hygiene-topology-sync.ts",
    "hygiene:topology:verify": "node --loader ts-node/esm src/utils/verify-hygiene-topology.ts",
    "hygiene:proof:scope:sync": "node --loader ts-node/esm src/utils/hygiene-proof-scope-sync.ts",
    "hygiene:proof:verify": "node --loader ts-node/esm src/utils/verify-hygiene-proof.ts",
    "hygiene:exception:sync": "node --loader ts-node/esm src/utils/hygiene-exception-sync.ts",
    "hygiene:exception:verify": "node --loader ts-node/esm src/utils/verify-hygiene-exceptions.ts",
    "hygiene:platform:verify": "node --loader ts-node/esm src/utils/verify-hygiene-platform-parity.ts",
    "hygiene:deps:sync": "node --loader ts-node/esm src/utils/hygiene-external-deps-sync.ts",
    "commit:audit:verify": "node --loader ts-node/esm src/scripts/verify/verify-commit-audit-invariants.ts",
    "done-check": "npm run build && npm run plan:refresh && npm run edges:normalize && npm run plan:evidence:recompute && npm run document:evidence:link-runtime && npm run verification:proof:record && npm run registry:reconcile && npm run registry:verify && npm run registry:identity:verify && npm run edges:verify && npm run parser:contracts:verify && npm run query:contract:verify && npm run governance:metric:def:sync && npm run governance:metric:def:verify && npm run governance:attribution:backfill && npm run governance:metrics:snapshot && npm run governance:metrics:report && npm run governance:metrics:integrity:verify && npm run plan:deps:verify && npm run governance:stale:verify && npm run document:witness:advisory && npm run document:namespace:reconcile && npm run document:namespace:verify && npm run document:claims:grade && npm run document:claims:verify && npm run document:wording:verify && npm run integrity:snapshot && npm run integrity:snapshot:fields:verify && npm run integrity:verify",
    "document:witness:advisory": "node --loader ts-node/esm src/utils/verify-document-witness-advisory.ts",
    "document:namespace:audit": "node --loader ts-node/esm src/utils/document-namespace-audit.ts",
    "document:evidence:link-runtime": "node --loader ts-node/esm src/utils/link-document-runtime-evidence.ts",
    "governance:attribution:backfill": "node --loader ts-node/esm src/utils/governance-attribution-backfill.ts",
    "governance:metrics:snapshot": "node --loader ts-node/esm src/utils/governance-metrics-snapshot.ts",
    "governance:metrics:report": "node --loader ts-node/esm src/utils/governance-metrics-report.ts",
    "document:namespace:reconcile": "node --loader ts-node/esm src/utils/document-namespace-reconcile.ts",
    "document:namespace:verify": "node --loader ts-node/esm src/utils/verify-document-namespace-contract.ts",
    "document:claims:grade": "node --loader ts-node/esm src/utils/document-claim-support-grade.ts",
    "document:claims:verify": "node --loader ts-node/esm src/utils/verify-document-claim-support.ts",
    "governance:metrics:integrity:verify": "node --loader ts-node/esm src/utils/verify-governance-metrics-integrity.ts",
    "document:wording:verify": "node --loader ts-node/esm src/utils/verify-document-wording-contract.ts",
    "governance:metric:def:sync": "node --loader ts-node/esm src/utils/governance-metric-definition-sync.ts",
    "governance:metric:def:verify": "node --loader ts-node/esm src/utils/verify-governance-metric-definition-lineage.ts",
    "done-check:strict:smoke": "STRICT_SCOPED_DEPENDS_ON=true DOCUMENT_WITNESS_ENFORCE=false GOVERNANCE_METRICS_ENFORCE=false STALE_CHECK_SLA_MINUTES=10000 npm run done-check && npm run verification:done-check:capture:only",
    "done-check:strict:full": "STRICT_SCOPED_DEPENDS_ON=true DOCUMENT_WITNESS_ENFORCE=true GOVERNANCE_METRICS_ENFORCE=true npm run done-check && npm run verification:done-check:capture:only"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.1",
    "@parcel/watcher": "^2.5.1",
    "commander": "^14.0.0",
    "dotenv": "^17.2.3",
    "glob": "^11.0.3",
    "minimatch": "^10.2.4",
    "neo4j": "^2.0.0-RC2",
    "neo4j-driver": "^5.28.1",
    "openai": "^5.10.1",
    "ts-morph": "^26.0.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/neo4j": "^2.0.6",
    "@types/node": "^20.19.1",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^5.5.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "reflect-metadata": "^0.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "uuid": "^11.1.0",
    "vitest": "^4.0.18"
  }
}
